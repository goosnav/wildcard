# Copy to `.env` and fill in. Never commit a real .env (see .gitignore).
# All secrets here are read SERVER-SIDE ONLY (REQ-SEC-001) — they are never
# shipped to a client or embedded in a generated tool bundle.

# ─── Generation provider ──────────────────────────────────────────────────────
# The server prefers OpenRouter when OPENROUTER_API_KEY is set, otherwise it
# falls back to ANTHROPIC_API_KEY. Set WC_PROVIDER=stub to run fully offline
# with a deterministic fake model (no key, no cost) — useful for UI work + tests.

# OpenRouter (preferred). OpenAI-compatible; get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Direct Anthropic key (alternative to OpenRouter).
ANTHROPIC_API_KEY=sk-ant-...

# Generation model id. For OpenRouter use a namespaced slug
# (e.g. anthropic/claude-sonnet-4). For direct Anthropic use e.g. claude-sonnet-4-6.
# RE-VERIFY the current id + price before launch (OQ-03).
#   Cost-free testing: any OpenRouter slug ending in `:free`, e.g.
#   WC_MODEL=openai/gpt-oss-120b:free  (free tiers are heavily rate-limited).
WC_MODEL=anthropic/claude-sonnet-4

# Force the offline stub model regardless of keys. Unset for real generation.
# WC_PROVIDER=stub

# Log per-generation token usage incl. prompt-cache hit rate (the #1 COGS lever).
# Off by default to keep production logs quiet; set to 1 to confirm caching.
# WC_LOG_USAGE=1

# ─── Server ───────────────────────────────────────────────────────────────────
# Port for the local generation server.
PORT=8787

# Public URL of the web app, used to build magic-link sign-in URLs in emails.
# Defaults to http://localhost:5173 (the Vite dev server) when unset.
WC_APP_URL=http://localhost:5173

# CORS allow-origin for the /v1 API. In the single-container deploy the SPA and
# API share an origin, so this is moot. If you host the API on its own origin,
# set this to your exact web origin to lock it down. Defaults to "*" for dev.
# WC_CORS_ORIGIN=https://app.yourdomain.com

# Serve the built web app from this same server (single-origin, no CORS). Set to
# the host-web/dist directory. The Docker image sets this automatically; in local
# dev you normally use the Vite dev server instead and leave this unset.
# WC_WEB_DIR=/app/host-web/dist

# ─── Spend + abuse guard (REQ-NFR-006) ────────────────────────────────────────
# Per-user fixed-window rate limits (requests per minute; 0 disables a limit).
# WC_RL_GENERATE_PER_MIN=5     # tool generations per user per minute
# WC_RL_NET_PER_MIN=60         # data-provider proxy calls per user per minute
# Global COGS backstop: max tools generated per period across ALL users. Each
# shipped build is the unit of model spend, so this hard-caps the bill. 0 = off.
# WC_BUILD_CEILING=1000        # builds per period (default 1000)
# WC_BUILD_CEILING_PERIOD_MS=86400000   # period length in ms (default 24h)
# NOTE: these counters are in-process — correct for the single-container deploy.
# Running multiple instances needs a shared store (Redis/Postgres) to be global.

# ─── Persistence (store backend) ──────────────────────────────────────────────
# With DATABASE_URL UNSET the server uses a local JSON file (server/.data/db.json)
# — zero setup, fine for dev and a tiny deployment. Set DATABASE_URL to a Postgres
# connection string (Neon, Supabase, RDS, …) to switch to the Postgres backend;
# the schema is created automatically on first connect. Hosted Postgres needs TLS
# (the default); append ?sslmode=disable only for a local plaintext server.
# Validate a real connection with: npm --workspace @wildcard/server run store:smoke
# DATABASE_URL=postgres://user:pass@host:5432/wildcard
# DB TLS: by default the connection is encrypted but the server cert is NOT
# verified (hosted Postgres often presents chains Node won't verify out of the
# box). To defend against a MITM on the DB link, either pin the provider's CA
# cert (PEM) or require verification against the system CA store:
# WC_DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# WC_DB_SSL_STRICT=1

# ─── Email (magic-link auth) ──────────────────────────────────────────────────
# Without RESEND_API_KEY the server logs the sign-in link to the console and the
# UI shows a one-tap "Continue (dev)" button — no email is sent (the dev path).
# Set both to actually deliver links via Resend (https://resend.com). Once a key
# is present, a send failure returns an error to the client instead of leaking
# the link inline — so verify WC_EMAIL_FROM uses a domain you've verified in Resend.
# RESEND_API_KEY=re_...
# WC_EMAIL_FROM=Wild Card <login@yourdomain.com>
# Override the Resend API base (default https://api.resend.com) — for pointing at
# a local mock in tests. Leave unset in production.
# RESEND_API_BASE=https://api.resend.com

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
# Until STRIPE_SECRET_KEY + STRIPE_PRICE_ID are set, the checkout endpoint
# returns 503 and the paywall says "subscriptions aren't switched on yet".
# STRIPE_PRICE_ID is the recurring $9.99/mo price. STRIPE_WEBHOOK_SECRET verifies
# the webhook signature — REQUIRED in production so entitlements can't be forged.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Eval harness ─────────────────────────────────────────────────────────────
# `npm run eval` exits non-zero if the corpus pass rate falls below this gate.
# EVAL_MIN_PASS_RATE=0.7
