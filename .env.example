# Copy to `.env` and fill in. Never commit a real .env (see .gitignore).


OPENROUTER_API_KEY=sk-or-v1-...


# Anthropic API key — used server-side ONLY (REQ-SEC-001). Never ship this to a
# client or embed it in a generated tool bundle.
ANTHROPIC_API_KEY=sk-ant-...

# Generation model id. RE-VERIFY the current id + price before launch (OQ-03).
WC_MODEL=claude-sonnet-4-6

# Port for the local generation server.
PORT=8787
